{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "stitch": {
      "type": "remote",
      "url": "https://stitch.googleapis.com/mcp",
      "enabled": true,
      "headers": {
        "X-Goog-Api-Key": "env:STITCH_API_KEY"
      }
    },
    "github": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-github"
      ],
      "environment": {
        "GITHUB_TOKEN": "env:GITHUB_TOKEN"
      },
      "enabled": true
    },
    "vercel": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@vercel/mcp-adapter"
      ],
      "environment": {
        "VERCEL_TOKEN": "env:VERCEL_TOKEN"
      },
      "enabled": true
    }
  }
}
